# Copie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA suba o arquivo ".env" (com o token real) para repositórios públicos.

NEXUS_BASE_URL=http://IP.DO.SEU.NEXUS
NEXUS_TOKEN=seu_token_aqui

# Opcional: o relatório de tabulações nesta instalação exige um telefone
# específico (formato DDDNUMERO, ex: 4133221336) — sem isso, o dashboard.py
# pula esse relatório automaticamente. Descomente e preencha se quiser
# consultar o histórico de tabulações de um número específico por padrão:
# NEXUS_TELEFONE_TABULACOES=4133221336
