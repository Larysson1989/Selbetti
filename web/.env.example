# Essas variáveis devem ser configuradas em Vercel → Project Settings →
# Environment Variables (NÃO num arquivo .env commitado no repositório).
# Use este arquivo só como referência local caso rode "npm run dev".

# Mesma URL e Token já usados no dashboard.py
NEXUS_BASE_URL=https://SEU-DOMINIO.cloudnexcore.com.br
NEXUS_TOKEN=seu_token_aqui

# Senha compartilhada para acessar o painel web (escolha uma senha forte)
DASHBOARD_PASSWORD=escolha_uma_senha_forte

# String aleatória longa usada para assinar o cookie de sessão.
# Gere uma com: openssl rand -base64 32
AUTH_SECRET=gere_uma_string_aleatoria_longa_aqui
